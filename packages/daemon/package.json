{
  "name": "thoxcode-daemon",
  "version": "0.1.2",
  "description": "ThoxCode daemon for ThoxOS — Unix socket service exposing the agent over JSONL framing. Includes systemd unit and install script.",
  "keywords": [
    "thoxcode",
    "thox",
    "thoxos",
    "claude",
    "agent-sdk",
    "daemon",
    "systemd",
    "jetson"
  ],
  "homepage": "https://github.com/ttracx/thoxcode#readme",
  "bugs": {
    "url": "https://github.com/ttracx/thoxcode/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ttracx/thoxcode.git",
    "directory": "packages/daemon"
  },
  "license": "MIT",
  "author": "Tommy Xaypanya <tommy@vibecaas.com> (https://thox.ai)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./server": "./dist/server.js"
  },
  "bin": {
    "thoxcoded": "./dist/server.js"
  },
  "files": [
    "dist",
    "systemd",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "thoxcode-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
