{
  "name": "thoxcode-sandbox-runtime",
  "version": "0.1.2",
  "description": "Vercel Sandbox MCP tool adapters for ThoxCode — Bash/Read/Write/Edit/Ls executed inside per-session Firecracker microVMs.",
  "keywords": [
    "thoxcode",
    "thox",
    "vercel-sandbox",
    "claude",
    "agent-sdk",
    "mcp",
    "sandbox",
    "firecracker"
  ],
  "homepage": "https://github.com/ttracx/thoxcode#readme",
  "bugs": {
    "url": "https://github.com/ttracx/thoxcode/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ttracx/thoxcode.git",
    "directory": "packages/sandbox-runtime"
  },
  "license": "MIT",
  "author": "Tommy Xaypanya <tommy@vibecaas.com> (https://thox.ai)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.123",
    "thoxcode-core": "workspace:*",
