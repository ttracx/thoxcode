{
  "name": "thoxcode",
  "version": "0.1.0",
  "private": true,
  "description": "ThoxCode — THOX.ai's branded coding agent. Powered by Claude.",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "dev:cli": "pnpm --filter thoxcode-cli dev",
    "dev:bridge": "pnpm --filter thoxcode-web-bridge dev",
    "dev:sandbox": "pnpm --filter thoxcode-sandbox-app dev",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist .turbo .next"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
