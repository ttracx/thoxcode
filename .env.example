# ThoxCode environment template — copy to .env and fill in real values

# === Claude (required) ===
# Used as the Thox-managed key when users authenticate with Supabase
# instead of bringing their own.
ANTHROPIC_API_KEY=sk-ant-...
THOXCODE_DEFAULT_MODEL=claude-opus-4-7

# === Vercel Sandbox (required for remote execution) ===
# Production on Vercel: VERCEL_OIDC_TOKEN is injected automatically.
# Local/external: pull a dev token via `vercel link && vercel env pull`,
# OR use access-token auth below.
VERCEL_OIDC_TOKEN=
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# === ThoxQuantum bridge ===
THOX_QUANTUM_URL=http://localhost:8200

# === Web bridge ===
THOXCODE_BRIDGE_PORT=8787
THOXCODE_BRIDGE_ORIGIN=https://sandbox.thox.ai
THOXCODE_SESSION_TIMEOUT_MS=900000

# === Managed-key auth (Supabase, mirrors Thox.ai stack) ===
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# === sandbox.thox.ai (Next.js client) ===
NEXT_PUBLIC_THOXCODE_BRIDGE_URL=https://bridge.thox.ai
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
